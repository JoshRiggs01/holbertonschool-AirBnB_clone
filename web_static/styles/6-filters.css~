.filters .container {
  display: flex;
  align-items: center;
}

.locations,
.amenities {
  height: 100%;
  width: 25%;
  border-right: 1px solid #dddddd;
  border-top-left-radius: 4px;
  border-top-right-radius: 4px;
}

.locations .popover,
.amenities .popover {
  position: absolute;
  display: none;
  color: #fafafa;
  width: 100%;
  background-color: #fafafa;
  border: 1px solid #dddddd;
  border-radius: 4px;
  list-style: none;
}

